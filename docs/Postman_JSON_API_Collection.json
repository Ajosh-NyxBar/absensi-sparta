{
	"info": {
		"_postman_id": "si-json-data-api-smpn4",
		"name": "JSON Data API — Sistem Presensi & Penilaian SMPN 4 Purwakarta",
		"description": "Koleksi endpoint JSON Data API yang langsung mengembalikan data JSON (bukan HTML).\n\nBase URL: http://localhost:8000/api/v1\nAuth: Session-based (Cookie) — login dulu via POST /login\nFormat Response: JSON\n\nEndpoint ini terpisah dari web endpoint biasa. Semua response berupa JSON murni.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8000",
			"type": "string"
		},
		{
			"key": "api_url",
			"value": "http://localhost:8000/api/v1",
			"type": "string"
		},
		{
			"key": "csrf_token",
			"value": "",
			"type": "string"
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Auto-set CSRF token from cookie",
					"var xsrf = pm.cookies.get('XSRF-TOKEN');",
					"if (xsrf) {",
					"    pm.collectionVariables.set('csrf_token', decodeURIComponent(xsrf));",
					"}"
				]
			}
		}
	],
	"item": [
		{
			"name": "00. Authentication (Login)",
			"description": "Login terlebih dahulu untuk mendapatkan session cookie. Semua endpoint /api/v1/* membutuhkan autentikasi.",
			"item": [
				{
					"name": "GET Login Page (Ambil Cookie)",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"// Simpan CSRF token dari cookie",
									"var xsrf = pm.cookies.get('XSRF-TOKEN');",
									"if (xsrf) {",
									"    pm.collectionVariables.set('csrf_token', decodeURIComponent(xsrf));",
									"    pm.test('CSRF Token captured', function() {",
									"        pm.expect(xsrf).to.not.be.empty;",
									"    });",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/login",
							"host": ["{{base_url}}"],
							"path": ["login"]
						},
						"description": "Step 1: Buka halaman login untuk mendapatkan CSRF token dan session cookie."
					}
				},
				{
					"name": "POST Login (Admin)",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Login berhasil (redirect 302)', function() {",
									"    pm.expect(pm.response.code).to.be.oneOf([200, 302]);",
									"});",
									"var xsrf = pm.cookies.get('XSRF-TOKEN');",
									"if (xsrf) {",
									"    pm.collectionVariables.set('csrf_token', decodeURIComponent(xsrf));",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{"key": "Content-Type", "value": "application/x-www-form-urlencoded"},
							{"key": "X-CSRF-TOKEN", "value": "{{csrf_token}}"},
							{"key": "Accept", "value": "text/html"}
						],
						"body": {
							"mode": "urlencoded",
							"urlencoded": [
								{"key": "_token", "value": "{{csrf_token}}", "description": "CSRF Token"},
								{"key": "email", "value": "admin@admin.com", "description": "Email admin"},
								{"key": "password", "value": "password", "description": "Password"}
							]
						},
						"url": {
							"raw": "{{base_url}}/login",
							"host": ["{{base_url}}"],
							"path": ["login"]
						},
						"description": "Step 2: Login sebagai Admin. Setelah berhasil, session cookie aktif dan semua endpoint /api/v1/* bisa diakses.\n\nAkun default:\n- Admin: admin@admin.com / password\n- Guru: guru@smpn4.sch.id / password\n- Kepsek: kepsek@smpn4.sch.id / password"
					}
				}
			]
		},
		{
			"name": "01. Dashboard Stats",
			"description": "Statistik ringkasan dashboard.",
			"item": [
				{
					"name": "GET Dashboard Stats",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status 200', function() { pm.response.to.have.status(200); });",
									"pm.test('Response is JSON', function() { pm.response.to.be.json; });",
									"pm.test('Has data object', function() {",
									"    var json = pm.response.json();",
									"    pm.expect(json).to.have.property('data');",
									"    pm.expect(json.data).to.have.property('total_teachers');",
									"    pm.expect(json.data).to.have.property('total_students');",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{"key": "Accept", "value": "application/json"}
						],
						"url": {
							"raw": "{{api_url}}/dashboard",
							"host": ["{{api_url}}"],
							"path": ["dashboard"]
						},
						"description": "Mendapatkan statistik dashboard: total guru, siswa, kelas, mapel, dan presensi hari ini."
					}
				}
			]
		},
