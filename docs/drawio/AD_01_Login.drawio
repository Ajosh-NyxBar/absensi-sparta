          <mxGeometry x="125" y="170" width="120" height="50" as="geometry" />
        </mxCell>

        <!-- End Node - Cancel/Error retry leads back -->
        <mxCell id="end" value="" style="ellipse;html=1;shape=doubleCircle;whiteSpace=wrap;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="lane_user">
          <mxGeometry x="170" y="540" width="30" height="30" as="geometry" />
